{
  "manifest_version": 3,
  "author": "danv",
  "name": "Twitch Auto Points",
  "version": "1.3.1",
  "homepage_url": "https://github.com/Spring3/twitch-auto-points",
  "description": "Automatic twitch channel points collection",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["https://*.twitch.tv/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "{076d8ebb-5df6-48e0-a619-99315c395644}"
    }
  },
  "content_security_policy": {
    "extension_pages": "default-src 'self';"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["*://*.twitch.tv/*"]
    }
  ],
  "background": {
    "service_worker": "background/browserAction.js",
    "type": "module",
    "scripts": ["background/browserAction.js"]
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-color-16.png",
      "32": "icons/icon-color-32.png",
      "48": "icons/icon-color-48.png",
      "64": "icons/icon-color-64.png",
      "96": "icons/icon-color-96.png",
      "128": "icons/icon-color-128.png",
      "256": "icons/icon-color-256.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.twitch.tv/*"],
      "match_about_blank": false,
      "js": ["contentScripts/worker.js"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "64": "icons/icon-64.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png",
    "256": "icons/icon-256.png"
  }
}
